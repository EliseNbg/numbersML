{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numbersml.local/schemas/algorithm_config_v1.json",
  "title": "AlgorithmConfigV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "universe",
    "signal",
    "risk",
    "execution",
    "mode",
    "status"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "schema_version"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 120},
        "description": {"type": "string", "maxLength": 2000},
        "schema_version": {"type": "integer", "const": 1}
      }
    },
    "universe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbols", "timeframe"],
      "properties": {
        "symbols": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3}
        },
        "timeframe": {
          "type": "string",
          "enum": ["TICK", "1S", "1M", "5M", "15M", "1H", "4H", "1D"]
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "params"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["rsi", "macd", "sma_cross", "bollinger", "composite"]
        },
        "params": {"type": "object"}
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_position_size_pct", "max_daily_loss_pct"],
      "properties": {
        "max_position_size_pct": {"type": "number", "exclusiveMinimum": 0, "maximum": 100},
        "max_daily_loss_pct": {"type": "number", "exclusiveMinimum": 0, "maximum": 100},
        "stop_loss_pct": {"type": "number", "exclusiveMinimum": 0, "maximum": 100},
        "take_profit_pct": {"type": "number", "exclusiveMinimum": 0, "maximum": 100}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order_type"],
      "properties": {
        "order_type": {"type": "string", "enum": ["market", "limit"]},
        "slippage_bps": {"type": "number", "minimum": 0, "maximum": 500},
        "fee_bps": {"type": "number", "minimum": 0, "maximum": 200}
      }
    },
    "mode": {"type": "string", "enum": ["paper", "live"]},
    "status": {"type": "string", "enum": ["draft", "validated", "active", "paused", "archived"]}
  }
}
