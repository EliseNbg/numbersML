# Database Configuration
# Copy this file to .env and adjust values as needed

# Option 1: Set the full database URL (takes precedence)
TEST_DB_URL=postgresql://crypto:crypto_secret@localhost:5432/crypto_trading

# Option 2: Set individual components (used if TEST_DB_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=crypto
DB_PASS=crypto_secret
DB_NAME=crypto_trading

# Redis Configuration (for pipeline tests)
REDIS_URL=redis://localhost:6379
